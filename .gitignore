# ─── Repo público: solo lo necesario para que la página funcione ───
# El resto queda en local. No commitear:
#   docs/  .cursor/  supabase/  PLAN_MASTER.md  SLIPUP_MASTER_CONTEXT.md  schema_v2.sql
#   BACKLOG.md  SLIPUP_ORIGIN_2026.md  (documentación interna; no necesarios para que funcione la página)
# Ver también .cursor/rules/remote-config-security.mdc (checklist antes de commit/push).

# ─── Contenido interno / solo local (no exponer en repo público) ───
docs/
.cursor/
PLAN_MASTER.md
SLIPUP_MASTER_CONTEXT.md
schema_v2.sql
supabase/
BACKLOG.md
SLIPUP_ORIGIN_2026.md

# ─── Seguridad y secretos (nunca commitear) ───
# Config local con URLs y claves reales; generar remote.js con scripts/generate-remote.js
remote.local.js
*.local.js
!*.local.js.example

# Variables de entorno (claves, URLs, API keys)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
.env.staging
*.env

# Supabase: secretos locales (redundante con supabase/ arriba; por si se desea trackear supabase/ más adelante)
supabase/.env
supabase/.env.local

# Archivos de credenciales (nombres habituales)
credentials.json
secrets.json
**/firebase-adminsdk*.json
**/serviceAccount*.json
**/service-account*.json
config.local.*

# Certificados y claves
*.pem
*.key
*.crt
*.p12
*.pfx

# Copias de respaldo (pueden contener datos pegados por error)
*.backup
*~
.npmrc.local

# ─── No necesarios para que funcione la página ───
# Inventario de copy / notas internas (no hace falta en el repo público)
PHRASE_CATEGORIES.md
# Cuerpo de PR generado localmente (gh pr create --body-file)
.pr-body.md
# Dependencias (se instalan con npm install)
node_modules/

# Build y caché
dist/
build/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE (opcional; descomenta si no quieres compartir tu config)
# .vscode/
# .idea/

# Screenshots y assets locales (no forman parte del código)
*.png
*.jpg
*.jpeg
*.gif
!favicon.svg
# Imagen social para og:image (necesaria en el sitio)
!assets/social/og-slipup.png
