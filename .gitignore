# ─── Principio: no subir nada que comprometa el proyecto ───
# Secretos, claves, API keys, datos sensibles. Este .gitignore protege el repo
# ahora y cubre archivos que puedas añadir en el futuro. Revisar antes de commit.

# ─── Seguridad y secretos (nunca commitear) ───
# Config local con URLs y claves reales; generar remote.js con scripts/generate-remote.js
remote.local.js
*.local.js
!*.local.js.example

# Variables de entorno (claves, URLs, API keys)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
.env.staging
*.env

# Supabase: secretos locales
supabase/.env
supabase/.env.local

# Archivos de credenciales (nombres habituales)
credentials.json
secrets.json
**/firebase-adminsdk*.json
**/serviceAccount*.json
**/service-account*.json
config.local.*

# Certificados y claves
*.pem
*.key
*.crt
*.p12
*.pfx

# Copias de respaldo (pueden contener datos pegados por error)
*.backup
*~
.npmrc.local

# ─── Información interna del proyecto (solo uso local) ───
# Planes y contexto de agente
PLAN_MASTER.md
docs/AGENT_CONTEXT_*.md

# Procedimientos, calibración, análisis interno (exponen cómo funciona el sistema)
docs/INCIDENT_PROCEDURES.md
docs/TECHNICAL_OPERATIONS_RECOMMENDATIONS.md
docs/MODEL_DESIGN_AND_CALIBRATION.md
docs/TEXT_ANALYSIS.md
docs/GUIA_CONTADOR_NOT_ALONE.md
docs/OBSERVATORY_COMPLEXITY.md

# ─── No necesarios para que funcione la página ───
# Dependencias (se instalan con npm install)
node_modules/

# Supabase CLI: generados en local
supabase/.temp/

# Build y caché
dist/
build/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE (opcional; descomenta si no quieres compartir tu config)
# .vscode/
# .idea/

# Screenshots y assets locales (no forman parte del código)
*.png
*.jpg
*.jpeg
*.gif
!favicon.svg
Silpupobservatory.png
